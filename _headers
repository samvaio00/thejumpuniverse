# Cache editions for 24 hours (they don't change after generation)
/editions/*
  Cache-Control: public, max-age=86400

# HTML shell updates daily and carries fixes — keep it fresh
/
  Cache-Control: public, max-age=300, must-revalidate
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Static edition pages: today's page can change intraday; keep them fresh too
/edition/*
  Cache-Control: public, max-age=300, must-revalidate

# Cache static assets for 1 week
/*.css
  Cache-Control: public, max-age=604800
/*.js
  Cache-Control: public, max-age=604800
